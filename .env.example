# Crawled content DB (search reads crawled_items, embeddings, etc.)
DATABASE_URL=postgresql://dbuser@localhost:5432/autism_crawler

# User data DB (mzhu_test_ tables — written by collect, read-only from search)
# Leave blank to disable personalization and insights endpoints.
USER_DATABASE_URL=postgresql://dbuser@localhost:5432/autism_users

# Base URL of the collect service (used to persist weekly summaries)
COLLECT_BASE_URL=https://localhost:18001

DEFAULT_RESULT_LIMIT=10
MAX_RESULT_LIMIT=50
LOG_LEVEL=INFO
